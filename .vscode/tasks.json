{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript 监视",
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "启动前端开发环境",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/src/webview-ui"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Compiled successfully|listening on port|started"
          }
        }
      ]
    },
    {
      "label": "启动多个任务",
      "dependsOn": ["TypeScript 监视", "启动前端开发环境"],
      "dependsOrder": "sequence",
      "runOptions": {
        "runOn": "default"
      }
    }
  ]
}
